        "key-vault",
        "vault",
        "key management",
        "jwt",
        "jwe",
        "jwk",
        "jose",
        "client"
    ],
    "main": "index.js",
    "bin": {
        "kv-client": "./kv-client"
    },
    "files": [
        "index.js",
        "kvclient.js",
        "kv-client",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "test": "node --test test/*.test.js"
    },
    "dependencies": {
        "optist": "^2.0.1"
    },
    "repository": {
